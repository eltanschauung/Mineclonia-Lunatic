# Cutting board mesh (0.9 x ~0.1 x ~0.75), bottom aligned to node bottom.
# Drip groove profile (coordinates floored to 0.05 steps):
# - outer 9x9 rim: top at y=-0.40
# - 8x8 groove ring: top at y=-0.45
# - inner 7x7 plateau: top at y=-0.40
o cutting_board

# Dimensions (half-size):
# X: 9/9 -> 0.45, 8/9 -> 0.40, 7/9 -> 0.35
# Z slimmed by 0.15 total (then floored to 0.05 steps): 9/9 -> [-0.40..0.35], 8/9 -> [-0.35..0.30], 7/9 -> [-0.30..0.25]

# Bottom (outer)
v -0.45 -0.50 -0.40
v  0.45 -0.50 -0.40
v  0.45 -0.50  0.35
v -0.45 -0.50  0.35

# Top outer rim (9x9) at full height
v -0.45 -0.40 -0.40
v  0.45 -0.40 -0.40
v  0.45 -0.40  0.35
v -0.45 -0.40  0.35

# Rim inner boundary (8x8) at full height (start of groove drop)
v -0.40 -0.40 -0.35
v  0.40 -0.40 -0.35
v  0.40 -0.40  0.30
v -0.40 -0.40  0.30

# Groove outer edge (8x8) at lowered height
v -0.40 -0.45 -0.35
v  0.40 -0.45 -0.35
v  0.40 -0.45  0.30
v -0.40 -0.45  0.30

# Groove inner edge (7x7) at lowered height
v -0.35 -0.45 -0.30
v  0.35 -0.45 -0.30
v  0.35 -0.45  0.25
v -0.35 -0.45  0.25

# Inner plateau (7x7) at full height
v -0.35 -0.40 -0.30
v  0.35 -0.40 -0.30
v  0.35 -0.40  0.25
v -0.35 -0.40  0.25

vt 0 0
vt 1 0
vt 1 1
vt 0 1

# Bottom
f 1/1 3/3 2/2
f 1/1 4/4 3/3

# Outer sides (bottom -> top outer rim)
# north (-z)
f 1/1 2/2 6/3
f 1/1 6/3 5/4
# south (+z)
f 4/1 8/4 7/3
f 4/1 7/3 3/2
# west (-x)
f 1/1 5/2 8/3
f 1/1 8/3 4/4
# east (+x)
f 2/1 3/4 7/3
f 2/1 7/3 6/2

# Top outer rim ring (9x9 -> 8x8) at full height
# north band
f 5/1 6/2 10/3
f 5/1 10/3 9/4
# south band
f 8/1 12/4 11/3
f 8/1 11/3 7/2
# west band
f 5/1 9/2 12/3
f 5/1 12/3 8/4
# east band
f 6/1 7/4 11/3
f 6/1 11/3 10/2

# Vertical drop wall at 8x8 boundary (full -> groove)
# north (-z)
f 9/1 10/2 14/3
f 9/1 14/3 13/4
# south (+z)
f 12/1 16/4 15/3
f 12/1 15/3 11/2
# west (-x)
f 9/1 13/2 16/3
f 9/1 16/3 12/4
# east (+x)
f 10/1 11/4 15/3
f 10/1 15/3 14/2

# Groove floor ring (8x8 -> 7x7) at lowered height
# north band
f 13/1 14/2 18/3
f 13/1 18/3 17/4
# south band
f 16/1 20/4 19/3
f 16/1 19/3 15/2
# west band
f 13/1 17/2 20/3
f 13/1 20/3 16/4
# east band
f 14/1 15/4 19/3
f 14/1 19/3 18/2

# Vertical rise wall at 7x7 boundary (groove -> inner plateau)
# north (-z)
f 17/1 18/2 22/3
f 17/1 22/3 21/4
# south (+z)
f 20/1 24/4 23/3
f 20/1 23/3 19/2
# west (-x)
f 17/1 21/2 24/3
f 17/1 24/3 20/4
# east (+x)
f 18/1 19/4 23/3
f 18/1 23/3 22/2

# Top inner plateau (7x7) at full height
f 21/1 22/2 23/3
f 21/1 23/3 24/4

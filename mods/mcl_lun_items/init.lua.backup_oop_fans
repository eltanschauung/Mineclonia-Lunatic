function GroundProjectilePrototype:explode_ground(pos)
	if not pos then
		return
	end
	spawn_geyser_particles(pos, self.light_entity)
	apply_explosion_damage(pos, self.damage, self:get_reason(), 1.2)
	if self.object then
		self.object:remove()
	end

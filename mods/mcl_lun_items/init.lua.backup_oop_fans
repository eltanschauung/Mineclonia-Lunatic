	end
	return ("%s\n%s"):format(desc, text)
end

local function build_lun_description(def)
	if not def then return "" end
	local lines = {}
	if def.description then
		if def.color then
			lines[#lines + 1] = core.colorize(def.color, def.description)
		else
			lines[#lines + 1] = def.description
		end
	end
	if def.durability and def.durability > 0 then
		lines[#lines + 1] = S("Durability: @1 uses", def.durability)
	end
	if def.damage then
		lines[#lines + 1] = S("Damage: @1", def.damage)
	end
	if def.light_level then
		lines[#lines + 1] = S("Luminance: @1", def.light_level)
	end
	if def.explosion_radius then
		lines[#lines + 1] = S("Explosion radius: @1", def.explosion_radius)
	end
	return table.concat(lines, "\n")
end

